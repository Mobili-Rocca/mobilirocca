---
import Logo from "./Logo.astro";
import type { Lang } from "../i18n/ui";
import { useT } from "../i18n/ui";
import { business, hours, waLink, hasWhatsapp } from "../config/site";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useT(lang);
const c = t.contact;
const year = new Date().getFullYear();
const wa = hasWhatsapp ? waLink(c.waText) : "";
const isIt = lang === "it";

const hoursShort = [
  { d: isIt ? "Lun – Ven" : "Mon – Fri", h: hours[0].h!.join("  ·  ") },
  { d: isIt ? "Sabato" : "Saturday", h: hours[5].h!.join("  ·  ") },
  { d: isIt ? "Domenica" : "Sunday", h: c.closed },
];
---

<footer class="footer">
  <div class="u-wrap">
    <div class="top">
      <a href={isIt ? "/" : "/en/"} class="brandwrap" aria-label="Mobili Rocca">
        <Logo />
      </a>
      <p class="tag">{t.footer.tagline}</p>
    </div>

    <div class="cols">
      <nav class="col" aria-label="Footer">
        <span class="ctitle">{t.footer.explore}</span>
        <ul>
          {t.nav.items.map((i) => <li><a class="link-wipe" href={i.href}>{i.label}</a></li>)}
        </ul>
      </nav>

      <div class="col">
        <span class="ctitle">{t.footer.contact}</span>
        <ul>
          <li><a class="link-wipe" href={business.mapLink} target="_blank" rel="noopener">{business.address.street}, {business.address.city}</a></li>
          <li><a class="link-wipe" href={`tel:${business.phone.href}`}>{business.phone.display}</a></li>
          {hasWhatsapp && (
            <li><a class="link-wipe" href={wa} target="_blank" rel="noopener">WhatsApp</a></li>
          )}
          <li><a class="link-wipe" href={`mailto:${business.email}`}>{business.email}</a></li>
          <li>
            <a class="link-wipe fb" href={business.social.facebook} target="_blank" rel="noopener">
              <svg class="fbi" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.43c0-3.014 1.792-4.677 4.533-4.677 1.313 0 2.686.235 2.686.235v2.953H15.83c-1.49 0-1.955.93-1.955 1.886v2.264h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
              </svg>
              Facebook ↗
            </a>
          </li>
        </ul>
      </div>

      <div class="col">
        <span class="ctitle">{t.footer.hours}</span>
        <ul class="hrs">
          {hoursShort.map((r) => (
            <li><span>{r.d}</span><span class="v">{r.h}</span></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="legal">
      <p>© {year} {business.legalName} — {business.vat}. {t.footer.rights}</p>
      <a href={t.nav.otherHref} class="lang">{isIt ? "English" : "Italiano"} →</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: var(--color-paper);
    padding-block: clamp(3.5rem, 8vh, 6rem) 2.5rem;
  }

  .top {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding-bottom: clamp(2.5rem, 5vh, 4rem);
    border-bottom: 1px solid rgba(244, 239, 229, 0.16);
  }
  @media (min-width: 768px) {
    .top { flex-direction: row; align-items: flex-end; justify-content: space-between; }
  }
  .brandwrap { font-size: clamp(2.6rem, 7vw, 4rem); color: var(--color-paper); }
  .tag {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: rgba(244, 239, 229, 0.65);
    max-width: 26ch;
  }

  .cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: clamp(2.5rem, 5vh, 4rem);
  }
  @media (min-width: 640px) { .cols { grid-template-columns: repeat(3, 1fr); } }

  .ctitle {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-red);
    margin-bottom: 1.3rem;
  }
  .col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .col a, .col li { font-size: 0.96rem; color: rgba(244, 239, 229, 0.85); }
  .fb { display: inline-flex; align-items: center; gap: 0.5rem; }
  .fbi { width: 0.95rem; height: 0.95rem; }
  .hrs li { display: flex; justify-content: space-between; gap: 1.5rem; max-width: 22rem; }
  .hrs .v { color: rgba(244, 239, 229, 0.6); font-variant-numeric: tabular-nums; }

  .legal {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(244, 239, 229, 0.16);
    font-size: 0.8rem;
    color: rgba(244, 239, 229, 0.55);
  }
  @media (min-width: 640px) { .legal { flex-direction: row; align-items: center; justify-content: space-between; } }
  .legal .lang { color: rgba(244, 239, 229, 0.8); font-weight: 600; letter-spacing: 0.06em; }
  .legal .lang:hover { color: var(--color-red); }
</style>
