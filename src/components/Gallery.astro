---
import { Image } from "astro:assets";
import SectionHead from "./SectionHead.astro";
import type { Lang } from "../i18n/ui";
import { useT } from "../i18n/ui";
import { business } from "../config/site";
import { images } from "../config/images";

interface Props { lang: Lang }
const { lang } = Astro.props;
const g = useT(lang).gallery;

const [g1, g2, g3, g4, g5, g6, g7, g8] = images.gallery;

// 3 columns × 3 tiles. Each column has one tall (4/5) + one wide (4/3) + one
// square (1/1) tile, so every column is the same height → the bottom lines up flush.
// One square cell is the Facebook link.
type Tile =
  | { src: ImageMetadata; alt: string; r: string }
  | { fb: true; r: string };

const cols: Tile[][] = [
  [
    { src: g2, alt: "Cucina moderna con isola e finiture scure", r: "r45" },
    { src: g1, alt: "Cucina classica in legno bianco con parete in pietra", r: "r43" },
    { src: g3, alt: "Allestimento dello showroom Mobili Rocca", r: "r11" },
  ],
  [
    { src: g4, alt: "Cucina moderna in legno con penisola", r: "r43" },
    { fb: true, r: "r11" },
    { src: g5, alt: "Camera da letto con armadio esposta in showroom", r: "r45" },
  ],
  [
    { src: g6, alt: "Armadio angolare e cabina armadio", r: "r11" },
    { src: g7, alt: "Zona giorno con cucina e soggiorno integrati", r: "r43" },
    { src: g8, alt: "Cucina moderna in legno e verde salvia", r: "r45" },
  ],
];
---

<section id="showroom" class="gallery u-wrap">
  <SectionHead num={g.num} eyebrow={g.eyebrow} title={g.title} intro={g.intro} />

  <div class="mason">
    {cols.map((col, ci) => (
      <div class="mcol">
        {col.map((t, ri) => (
          "fb" in t ? (
            <a class={`tile cta ${t.r}`} href={business.social.facebook} target="_blank"
              rel="noopener" data-reveal style={`--reveal-delay:${(ci + ri) * 70}ms`}>
              <span class="cta-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.43c0-3.014 1.792-4.677 4.533-4.677 1.313 0 2.686.235 2.686.235v2.953H15.83c-1.49 0-1.955.93-1.955 1.886v2.264h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
                </svg>
              </span>
              <span class="cta-text">{g.cta}</span>
              <span class="cta-arr" aria-hidden="true">↗</span>
            </a>
          ) : (
            <figure class={`tile zoomwrap ${t.r}`} data-reveal style={`--reveal-delay:${(ci + ri) * 70}ms`}>
              <Image src={t.src} alt={t.alt} widths={[440, 700, 1000]}
                sizes="(min-width:1024px) 31vw, (min-width:640px) 47vw, 92vw" class="img" />
            </figure>
          )
        ))}
      </div>
    ))}
  </div>
</section>

<style>
  .gallery { padding-block: clamp(5rem, 12vh, 9rem); }

  /* Desktop: 3 equal-height columns (flush bottom) */
  .mason {
    margin-top: clamp(3rem, 6vh, 5rem);
    display: flex;
    gap: 1.5rem;
  }
  .mcol {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Tablet/mobile: flatten columns into a simple masonry */
  @media (max-width: 1023px) {
    .mason { display: block; columns: 2; column-gap: 1.25rem; }
    .mcol { display: contents; }
    .tile { margin-bottom: 1.25rem; break-inside: avoid; }
  }
  @media (max-width: 639px) {
    .mason { columns: 1; }
  }

  .tile {
    display: block;
    overflow: hidden;
    background: var(--color-paper-2);
  }
  .r45 { aspect-ratio: 4 / 5; }
  .r43 { aspect-ratio: 4 / 3; }
  .r11 { aspect-ratio: 1 / 1; }

  .img { width: 100%; height: 100%; object-fit: cover; }

  .cta {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--color-ink);
    color: var(--color-paper);
    transition: background 0.4s ease;
  }
  .cta:hover { background: var(--color-red-deep); }
  .cta-mark { display: inline-flex; }
  .cta-mark svg { width: 2.5rem; height: 2.5rem; display: block; }
  .cta-text {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    line-height: 1.1;
    max-width: 12ch;
  }
  .cta-arr {
    align-self: flex-end;
    font-size: 1.4rem;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .cta:hover .cta-arr { transform: translate(4px, -4px); }
</style>
