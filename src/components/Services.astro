---
import SectionHead from "./SectionHead.astro";
import type { Lang } from "../i18n/ui";
import { useT } from "../i18n/ui";

interface Props { lang: Lang }
const { lang } = Astro.props;
const s = useT(lang).services;

const icons = [
  // design / pencil + ruler
  `<path d="M3 21l3.5-1 11-11-2.5-2.5-11 11L3 21z"/><path d="M14 6.5L17.5 10"/>`,
  // delivery truck
  `<path d="M3 6h11v9H3zM14 9h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.8"/><circle cx="17.5" cy="18" r="1.8"/>`,
  // assembly / wrench
  `<path d="M14.5 6.5a3.6 3.6 0 0 0-4.9 4.5L4 16.6 7.4 20l5.6-5.6a3.6 3.6 0 0 0 4.5-4.9l-2.3 2.3-2-2 2.3-2.3z"/>`,
  // showroom / store
  `<path d="M4 9l1-4h14l1 4M4 9h16M4 9v11h16V9M9 20v-6h6v6"/>`,
];
---

<section id="servizi" class="services">
  <div class="u-wrap">
    <SectionHead num={s.num} eyebrow={s.eyebrow} title={s.title} light />

    <div class="grid">
      {s.items.map((item, i) => (
        <article class="srv" data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <div class="srv-top">
            <span class="srv-num">0{i + 1}</span>
            <svg class="srv-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
              set:html={icons[i]} />
          </div>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
        </article>
      ))}
    </div>

    <div class="more" data-reveal>
      <span class="more-label">{s.moreLabel}</span>
      <ul class="chips">
        {s.more.map((m) => <li>{m}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-ink);
    color: var(--color-paper);
    padding-block: clamp(5rem, 12vh, 9rem);
  }

  .grid {
    margin-top: clamp(3rem, 6vh, 5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 768px) { .grid { grid-template-columns: repeat(2, 1fr); column-gap: 3.5rem; } }

  .srv {
    padding: 2.2rem 0;
    border-top: 1px solid rgba(244, 239, 229, 0.16);
  }
  .srv-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.4rem;
  }
  .srv-num {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--color-red);
  }
  .srv-ic { width: 1.9rem; height: 1.9rem; color: rgba(244, 239, 229, 0.85); }
  .srv h3 {
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
    font-weight: 380;
    margin-bottom: 0.7rem;
  }
  .srv p {
    font-size: 0.98rem;
    line-height: 1.55;
    color: rgba(244, 239, 229, 0.7);
    max-width: 38ch;
  }

  .more {
    margin-top: clamp(3rem, 6vh, 4.5rem);
    padding-top: 2rem;
    border-top: 1px solid rgba(244, 239, 229, 0.16);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  @media (min-width: 768px) { .more { flex-direction: row; align-items: baseline; gap: 2.5rem; } }
  .more-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(244, 239, 229, 0.65);
    white-space: nowrap;
  }
  .chips { display: flex; flex-wrap: wrap; gap: 0.6rem 0.7rem; list-style: none; padding: 0; margin: 0; }
  .chips li {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-paper);
    border: 1px solid rgba(244, 239, 229, 0.25);
    border-radius: 999px;
    padding: 0.5rem 1.05rem;
    transition: border-color 0.3s ease, color 0.3s ease;
  }
  .chips li:hover { border-color: var(--color-red); color: #fff; }
</style>
