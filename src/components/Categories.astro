---
import { Image } from "astro:assets";
import SectionHead from "./SectionHead.astro";
import type { Lang } from "../i18n/ui";
import { useT } from "../i18n/ui";
import { images } from "../config/images";

interface Props { lang: Lang }
const { lang } = Astro.props;
const c = useT(lang).cats;

const imgs: Record<string, ImageMetadata> = images.categories;
---

<section id="catalogo" class="cats u-wrap">
  <SectionHead num={c.num} eyebrow={c.eyebrow} title={c.title} intro={c.intro} />

  <div class="grid">
    {c.items.map((item, i) => (
      <a href="#contatti" class="cat" data-reveal style={`--reveal-delay:${i * 90}ms`}>
        <div class="zoomwrap media">
          <Image
            src={imgs[item.img]}
            alt={item.title}
            widths={[400, 640, 900]}
            sizes="(min-width:1024px) 22vw, (min-width:640px) 45vw, 90vw"
            class="img"
          />
          <span class="idx">0{i + 1}</span>
        </div>
        <div class="body">
          <h3>{item.title}</h3>
          <span class="arr" aria-hidden="true">→</span>
        </div>
        <p class="desc">{item.desc}</p>
      </a>
    ))}
  </div>

  <div class="more" data-reveal>
    <span class="more-label">{c.moreLabel}</span>
    <ul class="chips">
      {c.more.map((m) => <li>{m}</li>)}
    </ul>
  </div>
</section>

<style>
  .cats { padding-block: clamp(5rem, 12vh, 9rem); }

  .grid {
    margin-top: clamp(3rem, 6vh, 5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem 1.75rem;
  }
  @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .grid { grid-template-columns: repeat(4, 1fr); } }
  /* Editorial vertical stagger on desktop */
  @media (min-width: 1024px) {
    .cat:nth-child(even) { transform: translateY(3.25rem); }
  }

  .cat { display: block; }
  .media {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--color-paper-2);
  }
  .img { width: 100%; height: 100%; object-fit: cover; }
  .idx {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #fff;
    background: color-mix(in srgb, var(--color-red) 92%, transparent);
    padding: 0.3rem 0.55rem;
  }
  .body {
    margin-top: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-line);
  }
  .body h3 { font-size: 1.6rem; font-weight: 400; }
  .arr {
    color: var(--color-red);
    font-size: 1.1rem;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .cat:hover .arr { transform: translate(4px, -4px); }
  .desc {
    margin-top: 0.7rem;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
  }

  .more {
    margin-top: clamp(5rem, 9vh, 7rem);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
  }
  @media (min-width: 768px) {
    .more { flex-direction: row; align-items: baseline; gap: 2.5rem; }
  }
  .more-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    white-space: nowrap;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.7rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .chips li {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink);
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    padding: 0.5rem 1.05rem;
    transition: border-color 0.3s ease, color 0.3s ease, background 0.3s ease;
  }
  .chips li:hover {
    border-color: var(--color-red);
    color: var(--color-red);
  }
</style>
